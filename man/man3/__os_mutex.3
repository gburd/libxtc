.Nd portable mutexes, rwlocks, condition variables, and semaphores
.Sh SYNOPSIS
.In os_thread.h
.Pp
.Ft int
.Fn __os_mutex_init "__os_mutex_t *m"
.Ft int
.Fn __os_mutex_destroy "__os_mutex_t *m"
.Ft int
.Fn __os_mutex_lock "__os_mutex_t *m"
.Ft int
.Fn __os_mutex_trylock "__os_mutex_t *m"
.Ft int
.Fn __os_mutex_unlock "__os_mutex_t *m"
.Pp
.Ft int
.Fn __os_rwlock_init "__os_rwlock_t *r"
.Ft int
.Fn __os_rwlock_destroy "__os_rwlock_t *r"
.Ft int
.Fn __os_rwlock_rdlock "__os_rwlock_t *r"
.Ft int
.Fn __os_rwlock_wrlock "__os_rwlock_t *r"
.Ft int
.Fn __os_rwlock_unlock "__os_rwlock_t *r"
.Pp
.Ft int
.Fn __os_cond_init "__os_cond_t *c"
.Ft int
.Fn __os_cond_destroy "__os_cond_t *c"
.Ft int
.Fn __os_cond_wait "__os_cond_t *c" "__os_mutex_t *m"
.Ft int
.Fn __os_cond_signal "__os_cond_t *c"
