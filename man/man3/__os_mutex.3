.Dt __OS_MUTEX 3
.Os
.Sh NAME
.Nm __os_mutex_init ,
.Nm __os_mutex_destroy ,
.Nm __os_mutex_lock ,
.Nm __os_mutex_trylock ,
.Nm __os_mutex_unlock ,
.Nm __os_rwlock_init ,
.Nm __os_rwlock_destroy ,
