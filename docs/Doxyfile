# Doxyfile for libxtc.
#
# Generates the API + guide site published to Codeberg Pages
# (canonical) and validated on GitHub.  Mirrors the lime project's
# Doxygen setup: markdown guides plus C-header API extraction, with
# the repository README as the main page.

# -- Project settings --
PROJECT_NAME           = "libxtc"
PROJECT_NUMBER         = "0.4.0"
PROJECT_BRIEF          = "Async concurrency for C: Tokio + Seastar + BEAM, in one library"
PROJECT_LOGO           =
OUTPUT_DIRECTORY       = api

# -- Build settings --
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = NO

# -- Input files --
# README as main page, the user-facing markdown guides, and the
# public headers under src/inc for API extraction.  Internal docs
# (claims sheets, KVM runbooks, milestone notes) are intentionally
# omitted.
INPUT                  = ../README.md \
                         ./getting-started.md \
                         ./ARCHITECTURE.md \
                         ./API.md \
                         ./locks.md \
                         ./abi-stability.md \
                         ./KNOWN_ISSUES.md \
                         ./M_BEAM_LESSONS.md \
                         ./M_LRLOCK_COW.md \
                         ./M_MULTI_HEAD_RECV.md \
                         ./M_SQLXTC_HARDFORK.md \
                         ./M_SQLXTC_GREENFIELD.md \
                         ./M_LIBXTC_PG_BOUNDARY.md \
                         ./M_WINDOWS_MATRIX.md \
                         ./M_TLS_MATRIX.md \
                         ./M_LIBC_MATRIX.md \
                         ../src/inc/

FILE_PATTERNS          = *.h *.md
RECURSIVE              = NO
# Internal-only header is not part of the public API surface.
EXCLUDE                = ../src/inc/xtc_int.h
EXCLUDE_PATTERNS       = */test_* */bench/*

USE_MDFILE_AS_MAINPAGE = ../README.md

# -- Source browser --
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# -- Output format --
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE_HUE    = 209
HTML_COLORSTYLE_SAT    = 80
HTML_COLORSTYLE_GAMMA  = 90
HTML_DYNAMIC_SECTIONS  = YES
HTML_INDEX_NUM_ENTRIES = 100
GENERATE_TREEVIEW      = YES
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO

# -- Other output formats (disabled) --
GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

# -- Diagrams --
HAVE_DOT               = NO
COLLABORATION_GRAPH    = NO
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
GRAPHICAL_HIERARCHY    = NO

# -- Preprocessing --
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
PREDEFINED             = __cplusplus \
                         _WIN32 \
                         "__P(args)=args" \
                         "PUBLIC:="

# -- Warnings --
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
WARN_FORMAT            = "$file:$line: $text"
# Surface doc-rot in CI logs without failing on the existing
# undocumented-symbol backlog.  Flip to YES once the public headers
# carry full Doxygen comments.
WARN_AS_ERROR          = NO

# GitHub-flavoured markdown anchor IDs so in-page TOC links resolve.
MARKDOWN_ID_STYLE      = GITHUB

# -- Grouping and navigation --
OPTIMIZE_OUTPUT_FOR_C  = YES
TYPEDEF_HIDES_STRUCT   = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES

# -- Markdown and styling --
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
TAB_SIZE               = 8
ALIASES                = "thread_safe=\par Thread Safety:^^" \
                         "ownership=\par Ownership:^^"

DOT_NUM_THREADS        = 0

# -- Layout --
FULL_PATH_NAMES        = YES
STRIP_FROM_PATH        = ..
STRIP_FROM_INC_PATH    = ../src/inc/
SHOW_INCLUDE_FILES     = YES
SHOW_GROUPED_MEMB_INC  = YES
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = NO

# -- Example paths --
EXAMPLE_PATH           = ../examples/
EXAMPLE_PATTERNS       = *.c *.h
EXAMPLE_RECURSIVE      = YES
