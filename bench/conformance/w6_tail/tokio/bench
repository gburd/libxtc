# bench/conformance/w6_tail/tokio/bench
#   Wrapper that builds (if needed) and runs the W6 Tokio benchmark.
#   run.sh discovers and invokes this script as the benchmark binary.
#
set -eu
SELF_DIR=$(cd "$(dirname "$0")" && pwd)

if [ ! -x "$SELF_DIR/target/release/bench" ]; then
    cargo build --release --manifest-path "$SELF_DIR/Cargo.toml" >&2
fi

exec "$SELF_DIR/target/release/bench" "$@"
