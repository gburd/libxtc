# bench/conformance/w7_timer/erlang/bench
#   Thin wrapper so run.sh can find a stable path.  Delegates to
#   escript main.erl, passing all arguments through.
#
# If escript is not on PATH (Erlang/OTP not installed), exits 1;
# run.sh will silently skip this (workload, runtime) pair.

set -eu
SELF_DIR=$(cd "$(dirname "$0")" && pwd)

if ! command -v escript >/dev/null 2>&1; then
    printf 'escript not found; install Erlang/OTP 21+\n' >&2
    exit 1
fi

exec escript "${SELF_DIR}/main.erl" "$@"
