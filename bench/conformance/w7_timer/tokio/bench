# bench/conformance/w7_timer/tokio/bench
#   Thin wrapper so run.sh can find a stable path regardless of Cargo
#   target layout.  Delegates to the release binary produced by:
#     cargo build --release
#
# If the binary is absent (Rust / Cargo not installed), the script
# exits 1; run.sh will silently skip this (workload, runtime) pair.

set -eu
SELF_DIR=$(cd "$(dirname "$0")" && pwd)
BINARY="${SELF_DIR}/target/release/bench"

if [ ! -x "$BINARY" ]; then
    printf 'tokio bench binary not built; run: cd %s && cargo build --release\n' \
        "$SELF_DIR" >&2
    exit 1
fi

exec "$BINARY" "$@"
