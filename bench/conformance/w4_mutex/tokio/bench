# bench/conformance/w4_mutex/tokio/bench
#   Thin wrapper so run.sh can find a stable path regardless of Cargo
#   target layout.  Runs BOTH the tokio::sync::Mutex bench (async
#   mutex; what an operator who doesn't know better would pick) and
#   the parking_lot::Mutex bench (raw OS mutex; the *fair*
#   comparison against xtc_lwlock and __os_mutex).
#
#   If the binaries are absent (Rust / Cargo not installed), the
#   script exits 1; run.sh will silently skip this (workload, runtime)
#   pair.

set -eu
SELF_DIR=$(cd "$(dirname "$0")" && pwd)

ASYNC_BIN="${SELF_DIR}/target/release/bench"
PL_BIN="${SELF_DIR}/target/release/bench_pl"

if [ ! -x "$ASYNC_BIN" ] || [ ! -x "$PL_BIN" ]; then
    printf 'tokio bench binaries not built; run: cd %s && cargo build --release\n' \
        "$SELF_DIR" >&2
    exit 1
fi

# Run both; the harness expects one line per (workload, runtime).
"$ASYNC_BIN" "$@"
"$PL_BIN" "$@"
