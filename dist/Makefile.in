# PBT tests.  Build against the optional hegel-c library when
# --with-hegel was passed at configure time; otherwise the test
# stubs print SKIP and return 0.
PBT_CFLAGS	= $(CFLAGS) $(CPPFLAGS) $(XTC_HEGEL_CFLAGS) -I$(srcdir)/../test/pbt
PBT_LIBS	= $(STATIC_LIB) $(XTC_HEGEL_LIBS) $(LDFLAGS) $(LIBS)

pbt_atomic: $(srcdir)/../test/pbt/pbt_atomic.c $(STATIC_LIB)
	$(CC) $(PBT_CFLAGS) -o $@ $(srcdir)/../test/pbt/pbt_atomic.c $(PBT_LIBS)

pbt_alloc: $(srcdir)/../test/pbt/pbt_alloc.c $(STATIC_LIB)
	$(CC) $(PBT_CFLAGS) -o $@ $(srcdir)/../test/pbt/pbt_alloc.c $(PBT_LIBS)

pbt_timer: $(srcdir)/../test/pbt/pbt_timer.c $(STATIC_LIB)
	$(CC) $(PBT_CFLAGS) -o $@ $(srcdir)/../test/pbt/pbt_timer.c $(PBT_LIBS)

pbt_run_queue: $(srcdir)/../test/pbt/pbt_run_queue.c $(STATIC_LIB)
	$(CC) $(PBT_CFLAGS) -o $@ $(srcdir)/../test/pbt/pbt_run_queue.c $(PBT_LIBS)

pbt_async: $(srcdir)/../test/pbt/pbt_async.c $(STATIC_LIB)
	$(CC) $(PBT_CFLAGS) -o $@ $(srcdir)/../test/pbt/pbt_async.c $(PBT_LIBS)

pbt_proc: $(srcdir)/../test/pbt/pbt_proc.c $(STATIC_LIB)
	$(CC) $(PBT_CFLAGS) -o $@ $(srcdir)/../test/pbt/pbt_proc.c $(PBT_LIBS)

pbt_slab: $(srcdir)/../test/pbt/pbt_slab.c $(STATIC_LIB)
	$(CC) $(PBT_CFLAGS) -o $@ $(srcdir)/../test/pbt/pbt_slab.c $(PBT_LIBS)

pbt_lrlock: $(srcdir)/../test/pbt/pbt_lrlock.c $(STATIC_LIB)
	$(CC) $(PBT_CFLAGS) -o $@ $(srcdir)/../test/pbt/pbt_lrlock.c $(PBT_LIBS)

pbt_chan: $(srcdir)/../test/pbt/pbt_chan.c $(STATIC_LIB)
	$(CC) $(PBT_CFLAGS) -o $@ $(srcdir)/../test/pbt/pbt_chan.c $(PBT_LIBS)

pbt_deque: $(srcdir)/../test/pbt/pbt_deque.c $(STATIC_LIB)
	$(CC) $(PBT_CFLAGS) -o $@ $(srcdir)/../test/pbt/pbt_deque.c $(PBT_LIBS)

# -------------------------------------------------------------------------
# Install.
# -------------------------------------------------------------------------
install: all
	$(INSTALL) -d $(DESTDIR)$(libdir)
	$(INSTALL) -d $(DESTDIR)$(includedir)
	$(INSTALL) -d $(DESTDIR)$(mandir)/man3
	$(INSTALL) -d $(DESTDIR)$(mandir)/man7
	$(INSTALL_DATA) $(STATIC_LIB) $(DESTDIR)$(libdir)/$(STATIC_LIB)
	$(INSTALL_DATA) $(LIB_HDR_PUBLIC) $(DESTDIR)$(includedir)/xtc.h
	for m in $(srcdir)/../man/man3/*.3; do \
		$(INSTALL_DATA) $$m $(DESTDIR)$(mandir)/man3/; \
	done
	for m in $(srcdir)/../man/man7/*.7; do \
		$(INSTALL_DATA) $$m $(DESTDIR)$(mandir)/man7/; \
	done

# -------------------------------------------------------------------------
# Cleanup.
# -------------------------------------------------------------------------
clean:
	$(RM) $(LIB_OBJS) $(STATIC_LIB) $(TESTS_C) $(TESTS_PBT)

distclean: clean
	$(RM) Makefile xtc_config.h config.log config.status
	$(RM) -r autom4te.cache
