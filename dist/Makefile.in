	$(abs_top_srcdir)/../test/m0/test_docs_arch.sh \
	$(abs_top_srcdir)/../test/m0/test_docs_abi.sh \
	$(abs_top_srcdir)/../test/m0/test_man_coverage.sh \
	$(abs_top_srcdir)/../test/m0/test_man_lint.sh \
	$(abs_top_srcdir)/../test/m0/test_man_signatures.sh \
	$(abs_top_srcdir)/../test/m1/test_m1_man_coverage.sh \
	$(abs_top_srcdir)/../test/m2/test_m2_man.sh \
	$(abs_top_srcdir)/../test/m3/test_m3_man.sh \
	$(abs_top_srcdir)/../test/m4/test_m4_man.sh \
	$(abs_top_srcdir)/../test/m5/test_m5_man.sh \
	$(abs_top_srcdir)/../test/dist/test_s_all.sh \
	$(abs_top_srcdir)/../test/dist/test_s_include.sh \
	$(abs_top_srcdir)/../test/dist/test_s_include_idempotent.sh \
	$(abs_top_srcdir)/../test/dist/test_s_include_inline_comment.sh \
	$(abs_top_srcdir)/../test/dist/test_shellcheck.sh \
	$(abs_top_srcdir)/../test/dist/test_s_perm.sh

TESTS_C		= test_version test_header test_errors \
		  test_atomic test_alloc test_time \
		  test_thread test_tls test_mutex \
		  test_io_lifecycle test_io_register test_io_events test_io_wakeup \
		  test_loop test_task test_waker test_timer test_io_integration \
		  test_async \
		  test_fctx \
		  test_exec test_cross_wake test_deque test_steal \
		  test_chan test_chan_mpmc_bcast \
		  test_proc \
		  test_sync \
		  test_sup \
		  test_reg \
		  test_svr \
		  test_app \
		  test_mctx \
		  test_slab \
		  test_rcu \
		  test_lrlock \
		  test_lockmgr \
		  test_coverage_pump \
		  test_otp_proc_lib \
		  test_otp_gen_server \
		  test_otp_gen_server_phase2 \
		  test_otp_supervisor \
		  test_observability

TESTS_PBT	= pbt_atomic pbt_alloc pbt_timer pbt_run_queue pbt_async pbt_deque pbt_proc pbt_slab pbt_lrlock pbt_chan

# -------------------------------------------------------------------------
# Default goal.
# -------------------------------------------------------------------------
.PHONY: all check tests-c tests-sh tests-pbt clean distclean install uninstall

all: $(STATIC_LIB)

$(STATIC_LIB): $(LIB_OBJS)
	$(AR) rcs $@ $(LIB_OBJS)
	$(RANLIB) $@

# Pattern rule for compiling sources from ../src/ into ./*.o.
xtc_version.o: $(srcdir)/../src/xtc_version.c $(LIB_HDR_PUBLIC) xtc_config.h
	$(CC) $(CFLAGS) $(CPPFLAGS) -c -o $@ $(srcdir)/../src/xtc_version.c

xtc_strerror.o: $(srcdir)/../src/xtc_strerror.c $(LIB_HDR_PUBLIC) xtc_config.h
	$(CC) $(CFLAGS) $(CPPFLAGS) -c -o $@ $(srcdir)/../src/xtc_strerror.c

