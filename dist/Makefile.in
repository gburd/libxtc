srcdir		= @srcdir@
abs_top_srcdir	= @abs_top_srcdir@
builddir	= @builddir@
abs_builddir	= @abs_builddir@
prefix		= @prefix@
exec_prefix	= @exec_prefix@
libdir		= @libdir@
includedir	= @includedir@
mandir		= @mandir@

CC		= @CC@
CFLAGS		= @CFLAGS@ -Wall -Wextra -Wpedantic -fPIC -pthread @XTC_URING_CFLAGS@
CPPFLAGS	= @CPPFLAGS@ -I. -I$(srcdir)/../src/inc
LDFLAGS		= @LDFLAGS@ -pthread
LIBS		= @LIBS@ @XTC_URING_LIBS@ @XTC_PLATFORM_LIBS@
XTC_HEGEL_CFLAGS = @XTC_HEGEL_CFLAGS@
XTC_HEGEL_LIBS	 = @XTC_HEGEL_LIBS@
XTC_HEGEL_PBT	 = @XTC_HEGEL_PBT@
XTC_HEGEL_SERVER_COMMAND = @XTC_HEGEL_SERVER_COMMAND@
AR		= ar
RANLIB		= @RANLIB@
INSTALL		= @INSTALL@
INSTALL_DATA	= @INSTALL_DATA@
INSTALL_PROGRAM	= @INSTALL_PROGRAM@
RM		= rm -f

# -------------------------------------------------------------------------
# M0 sources.
# -------------------------------------------------------------------------
