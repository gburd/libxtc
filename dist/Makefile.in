# -------------------------------------------------------------------------
# Tests.
# -------------------------------------------------------------------------
check: tests-c tests-pbt tests-sh
	@echo "== M0 test summary =="
	@echo "All tests passed."

tests-c: $(TESTS_C)
	@for t in $(TESTS_C); do \
		echo "running C test: $$t"; \
		./$$t || exit 1; \
	done

tests-sh: $(STATIC_LIB)
	@for t in $(TESTS_SH); do \
		echo "running shell test: $$(basename $$t)"; \
		XTC_BUILD_DIR=$(abs_builddir) \
		XTC_SRC_DIR=$(abs_top_srcdir)/.. \
		sh $$t || exit 1; \
	done

tests-pbt: $(TESTS_PBT)
	@for t in $(TESTS_PBT); do \
		echo "running PBT: $$t"; \
		HEGEL_SERVER_COMMAND="$(XTC_HEGEL_SERVER_COMMAND)" \
		./$$t || exit 1; \
	done

# Build C tests.  Each links against the static lib.
test_version: $(srcdir)/../test/m0/test_version.c \
		$(srcdir)/../test/m0/munit.c $(STATIC_LIB)
	$(CC) $(CFLAGS) $(CPPFLAGS) \
		-I$(srcdir)/../test/m0 \
		-o $@ $(srcdir)/../test/m0/test_version.c \
		$(srcdir)/../test/m0/munit.c $(STATIC_LIB) $(LDFLAGS) $(LIBS)

test_header: $(srcdir)/../test/m0/test_header.c \
		$(srcdir)/../test/m0/munit.c $(STATIC_LIB)
	$(CC) $(CFLAGS) $(CPPFLAGS) \
		-I$(srcdir)/../test/m0 \
		-o $@ $(srcdir)/../test/m0/test_header.c \
		$(srcdir)/../test/m0/munit.c $(STATIC_LIB) $(LDFLAGS) $(LIBS)

test_errors: $(srcdir)/../test/m0/test_errors.c \
